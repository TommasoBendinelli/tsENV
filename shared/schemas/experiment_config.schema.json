{
  "$id": "experiment_config.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "exposed_variables": {
      "$ref": "#/definitions/ExposedVariablesConfig"
    },
    "sampling_rate_hz": {
      "exclusiveMinimum": 0,
      "type": "number"
    },
    "end_time_input_s": {
      "exclusiveMinimum": 0,
      "type": "number"
    },
    "detectability": {
      "$ref": "#/definitions/DetectabilityConfig"
    },
    "observable_signals": {
      "$ref": "#/definitions/ObservableSignalsConfig"
    }
  },
  "required": [
    "exposed_variables",
    "sampling_rate_hz",
    "end_time_input_s",
    "detectability",
    "observable_signals"
  ],
  "type": "object",
  "definitions": {
    "SamplingType": {
      "enum": ["uniform", "loguniform"],
      "type": "string"
    },
    "ObservableSignalType": {
      "enum": ["continuous", "impulse_like"],
      "type": "string"
    },
    "ObservableSignalSpecObject": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "$ref": "#/definitions/ObservableSignalType"
        }
      },
      "required": ["type"],
      "type": "object"
    },
    "ObservableSignalsList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {
          "const": "time"
        }
      }
    },
    "ObservableSignalsConfig": {
      "additionalProperties": false,
      "properties": {
        "observable_signals": {
          "$ref": "#/definitions/ObservableSignalsList"
        },
        "signal_type": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ObservableSignalSpecObject"
          }
        }
      },
      "required": ["observable_signals", "signal_type"],
      "type": "object"
    },
    "ContinuousDetectabilityConfig": {
      "additionalProperties": false,
      "properties": {
        "min_srd_distance": {
          "minimum": 0,
          "type": "number"
        },
        "epsilon_SRD": {
          "minimum": 0,
          "type": "number"
        },
        "minimum_consecurive_below_SRD": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "min_srd_distance",
        "epsilon_SRD",
        "minimum_consecurive_below_SRD"
      ],
      "type": "object"
    },
    "ImpulseLikeDetectabilityConfig": {
      "additionalProperties": false,
      "properties": {
        "min_srd_distance": {
          "minimum": 0,
          "type": "number"
        },
        "epsilon_SRD": {
          "minimum": 0,
          "type": "number"
        }
      },
      "required": [
        "min_srd_distance",
        "epsilon_SRD"
      ],
      "type": "object"
    },
    "DetectabilityConfig": {
      "additionalProperties": false,
      "properties": {
        "continuous": {
          "$ref": "#/definitions/ContinuousDetectabilityConfig"
        },
        "impulse_like": {
          "$ref": "#/definitions/ImpulseLikeDetectabilityConfig"
        },
        "signal_to_noise_ratio_db_thresholds": {
          "additionalProperties": {
            "$ref": "#/definitions/SignalToNoiseRatioThresholdPair"
          },
          "type": "object"
        }
      },
      "required": [
        "continuous",
        "impulse_like"
      ],
      "type": "object"
    },
    "SignalToNoiseRatioThresholdPair": {
      "items": {
        "type": "number"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "IntervalRange": {
      "items": {
        "type": "number"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array"
    },
    "VariableIntervalSpecObject": {
      "additionalProperties": false,
      "properties": {
        "allowed_intervals": {
          "$ref": "#/definitions/IntervalRange"
        },
        "min_srd_distance": {
          "minimum": 0,
          "type": "number"
        },
        "min_abs_dist": {
          "minimum": 0,
          "type": "number"
        },
        "sampling_strategy": {
          "$ref": "#/definitions/SamplingType"
        }
      },
      "required": [
        "allowed_intervals",
        "min_srd_distance",
        "min_abs_dist",
        "sampling_strategy"
      ],
      "type": "object"
    },
    "ParameterIntervalSpecObject": {
      "additionalProperties": false,
      "properties": {
        "allowed_intervals": {
          "$ref": "#/definitions/IntervalRange"
        },
        "min_srd_distance": {
          "minimum": 0,
          "type": "number"
        },
        "min_abs_dist": {
          "minimum": 0,
          "type": "number"
        },
        "sampling_strategy": {
          "$ref": "#/definitions/SamplingType"
        }
      },
      "required": [
        "allowed_intervals",
        "min_srd_distance",
        "min_abs_dist",
        "sampling_strategy"
      ],
      "type": "object"
    },
    "NamedIntervalMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/VariableIntervalSpecObject"
      }
    },
    "NamedParameterIntervalMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ParameterIntervalSpecObject"
      }
    },
    "ExposedVariablesConfig": {
      "additionalProperties": false,
      "properties": {
        "initial_state": {
          "$ref": "#/definitions/NamedIntervalMap"
        },
        "parameters": {
          "$ref": "#/definitions/NamedParameterIntervalMap"
        }
      },
      "type": "object"
    }
  }
}
